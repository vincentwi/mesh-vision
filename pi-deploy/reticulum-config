# Reticulum Configuration for MeshVision Pi Transport Node
# Auto-generated by MeshVision installer
# This node acts as a transport relay on the pi-star mesh network

[reticulum]
  enable_transport = True
  share_instance = Yes
  shared_instance_port = 37428
  instance_control_port = 37429
  panic_on_interface_error = No

[logging]
  loglevel = 4

# AutoInterface — automatically discovers peers on LAN
# Works over WiFi (pi-star network) and any wired connections
[interfaces]

  [[Default Interface]]
    type = AutoInterface
    enabled = True
    # group_id can be customized to create separate mesh segments
    # group_id = meshvision/pistar
    # Announce every 300 seconds
    announce_interval = 300

  # TCP Server — allows remote nodes (Mac, other Pis) to connect
  # Other nodes connect to this Pi as a TCPClientInterface
  [[TCP Server Interface]]
    type = TCPServerInterface
    enabled = True
    listen_ip = 0.0.0.0
    listen_port = 4242
    # Allow multiple simultaneous connections
    # i2p_tunneled = False

  # Uncomment to add a specific peer connection
  # [[TCP to Mac]]
  #   type = TCPClientInterface
  #   enabled = True
  #   target_host = 10.0.10.XX
  #   target_port = 4242
