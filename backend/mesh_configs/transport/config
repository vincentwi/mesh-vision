[reticulum]
  enable_transport = true
  share_instance = false
  shared_instance_port = 0
  panic_on_interface_error = no

[logging]
  loglevel = 4

[interfaces]
  [[TCP Server]]
    type = TCPServerInterface
    enabled = yes
    listen_ip = 127.0.0.1
    listen_port = 4242

  [[Auto]]
    type = AutoInterface
    enabled = yes

  [[TCP to Pi]]
    type = TCPClientInterface
    enabled = yes
    target_host = 10.0.10.82
    target_port = 4242
